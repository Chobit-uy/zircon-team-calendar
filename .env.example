# Turso (libSQL) database
TURSO_DATABASE_URL=libsql://your-db-name-yourorg.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token-here

# Secret for protecting /api/sync (Vercel sets this automatically for cron jobs)
CRON_SECRET=your-random-secret-here

# Google Apps Script URL (server-side only — never exposed to the browser)
GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/AKfycb.../exec

# Frontend API base URL
# Leave empty in production (Vercel serves /api/* from the same origin)
# Set to http://localhost:3000 when using `vercel dev` locally
VITE_API_BASE_URL=
